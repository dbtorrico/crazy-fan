<% content_for :title, "Resultado — Torcedor Maluco" %>

<div class="flex flex-col items-center justify-center min-h-screen px-4 text-center">
  <p class="text-sm font-semibold text-green-600 uppercase tracking-widest mb-2">Torcedor Maluco</p>

  <h1 class="text-2xl font-bold text-gray-800 mb-6">Fim de jogo!</h1>

  <p class="text-6xl font-extrabold text-green-500 mb-2"><%= @score %> de 5</p>

  <p class="text-base text-gray-500 mb-10">
    <% if @score == 5 %>
      Craque! Você mandou muito bem!
    <% elsif @score >= 3 %>
      Bom torcedor! Quase lá...
    <% elsif @score >= 1 %>
      Ainda dá pra melhorar — tenta de novo!
    <% else %>
      Não desanima, torcedor! Tenta de novo!
    <% end %>
  </p>

  <div data-controller="share"
       data-share-text-value="Fiz <%= @score %> de 5 no Torcedor Maluco, e você?"
       data-share-url-value="<%= new_game_url %>"
       class="w-full max-w-xs mb-4">
    <button data-action="click->share#share"
            class="w-full bg-blue-500 text-white px-8 py-4 rounded-lg text-xl font-bold min-h-[44px]">
      Compartilhar resultado
    </button>
    <p data-share-target="feedback" class="hidden text-sm text-green-600 mt-2 text-center"></p>
  </div>

  <%= button_to "Jogar de novo", games_path, method: :post,
      class: "bg-green-500 text-white px-8 py-4 rounded-lg text-xl font-bold min-h-[44px] w-full max-w-xs" %>
</div>
